# Copy thành .env và điền giá trị thật
# ❌ KHÔNG commit file .env lên Git

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

# App
APP_NAME=Day 12 AI Agent
APP_VERSION=1.0.0

# LLM (để trống → dùng mock LLM)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production

# Rate & Budget
RATE_LIMIT_PER_MINUTE=10
DAILY_BUDGET_USD=10.0

# Storage (Redis)
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=*
